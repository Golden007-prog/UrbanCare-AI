# ──────────────────────────────────────────────────────────
# UrbanCare AI — Frontend Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# VITE_API_URL: Backend server URL.
# In development, this points to your local backend.
# In production, point to your deployed backend.
VITE_API_URL=http://localhost:5001

# ⚠️  SECURITY NOTE:
# API keys (GEMINI_API_KEY, HF_TOKEN) are NO LONGER stored here.
# They are provided by users at runtime via the Credential Gate
# and stored securely in the backend session memory.
# This prevents keys from leaking into the public frontend bundle.
