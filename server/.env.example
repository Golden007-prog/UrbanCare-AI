# ──────────────────────────────────────────────────────────
# UrbanCare AI — Backend Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# Server port
PORT=5001

# JWT secret for authentication tokens (REQUIRED)
# Generate a strong random string for production
JWT_SECRET=replace_with_a_strong_secret

# Google OAuth (optional — for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Frontend URL (for CORS and OAuth callbacks)
CLIENT_URL=http://localhost:3000

# ──── AI API Keys ────
# These can also be provided per-session via the Credential Gate.
# If set here, they serve as ADMIN-LEVEL fallback defaults.
# User-provided keys from the Credential Gate override these.

# HuggingFace API token (for MedGemma, TxGemma, speech models)
HF_TOKEN=hf_xxxxx

# Google Gemini API key (for AI Clinical Copilot, chat)
GEMINI_API_KEY=

# ──── Dedicated AI Endpoints (optional) ────
# When set, image analysis routes to these instead of the generic HF Router.
MEDGEMMA_ENDPOINT=
HF_MEDGEMMA_URL=
TXGEMMA_ENDPOINT=

# ──── Database ────
# PostgreSQL / AlloyDB connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ──── Cloud Storage (optional) ────
GCS_BUCKET_NAME=
GCS_PROJECT_ID=
