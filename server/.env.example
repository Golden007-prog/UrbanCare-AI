# ─── Server ───────────────────────────────────────────────
PORT=5000

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret

# ─── Google OAuth 2.0 ────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Frontend URL (for CORS & redirect after OAuth) ──────
CLIENT_URL=http://localhost:3000

# ─── HuggingFace Inference API ────────────────────────────
# Get your token at https://huggingface.co/settings/tokens
# Required for AI features (MedGemma, TxGemma, MedASR)
# Without this token, AI endpoints return mock responses
HF_TOKEN=hf_your_huggingface_token_here

# ─── AlloyDB (PostgreSQL 17) ─────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# For AlloyDB with private IP:
#   postgresql://postgres:your_password@10.x.x.x:5432/urbancare
# For AlloyDB with Auth Proxy:
#   postgresql://postgres:your_password@127.0.0.1:5432/urbancare
DATABASE_URL=postgresql://postgres:your_password@HOST:5432/urbancare

# ─── Google Cloud Storage ────────────────────────────────
# Bucket name for storing uploaded reports & medical files
GCS_BUCKET_NAME=urbancare-reports
# GCP Project ID (optional if running on GCE with default credentials)
GCS_PROJECT_ID=your_gcp_project_id
