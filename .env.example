# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="http://localhost:5000"

# HF_TOKEN: HuggingFace API token for AI model inference.
# Required for MedGemma, TxGemma, and speech models.
HF_TOKEN=hf_xxxxx

# MEDGEMMA_ENDPOINT: Dedicated HuggingFace Inference Endpoint for MedGemma.
# When set, image analysis routes to this endpoint instead of the generic HF Router.
# Leave empty to use the default HF Router API.
MEDGEMMA_ENDPOINT=https://o4ae3bbz9fkwdn7f.us-east4.gcp.endpoints.huggingface.cloud
